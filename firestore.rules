rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents (Syllabus, etc.): 
    // - Authenticated users (students/admins) can read
    // - Only admins can write (assuming custom claim or specific admin UID check, 
    //   for now limiting to authenticated users for MVP simplicity, or strict check if we had claims)
    match /documents/{documentId} {
      allow read: if request.auth != null;
      // TODO: tightening write access to admins only in future
      allow write: if request.auth != null; 
    }
    
    // Chat History: Users can only read/write their own messages
    match /chatHistory/{messageId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Chat Sessions: Users can only read/write their own sessions
    match /chatSessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
